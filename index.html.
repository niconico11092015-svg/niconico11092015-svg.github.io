// ══════════════════════════════════════════
// NOMBRE ARCHIVO AUTOMÁTICO
// ══════════════════════════════════════════
function actualizarNombreArchivo(tipo, num) {
  const p = tipo === 'presupuestos' ? 'fp' : tipo === 'cuentas' ? 'cc' : 'ot';
  const ap = document.getElementById(`${p}-apellido`)?.value || '';
  const no = document.getElementById(`${p}-nombre`)?.value || '';
  const de = document.getElementById(`${p}-desc`)?.value || '';
  const nombre = nombreArchivo(tipo, num, ap, no, de);
  const el = document.getElementById(`${p}-nombre-archivo`);
  if (el) el.innerHTML = `<span>Nombre del archivo:</span>${nombre}`;
}

// ══════════════════════════════════════════
// FILAS DINÁMICAS
// ══════════════════════════════════════════
let filaPresupIdx = 0;
let filaCompraIdx = 0;
let filaPagoIdx = 0;

function agregarFilaPresup() {
  const idx = filaPresupIdx++;
  const cont = document.getElementById('fp-items');
  const div = document.createElement('div');
  div.className = 'tabla-fila compras';
  div.id = `fpi-${idx}`;
  div.innerHTML = `
    <input type="date" class="fpi-fecha" value="${hoy()}">
    <input type="text" class="fpi-desc" placeholder="Descripción...">
    <input type="number" class="fpi-cant" placeholder="1" min="0" oninput="calcPresup()">
    <input type="number" class="fpi-precio" placeholder="0" min="0" oninput="calcPresup()">
    <span class="total-cell fpi-total">—</span>
    <button class="del-btn" onclick="document.getElementById('fpi-${idx}').remove(); calcPresup()">✕</button>
  `;
  cont.appendChild(div);
}

function calcPresup() {
  let total = 0;
  document.querySelectorAll('#fp-items .tabla-fila').forEach(row => {
    const cant = parseFloat(row.querySelector('.fpi-cant')?.value) || 0;
    const precio = parseFloat(row.querySelector('.fpi-precio')?.value) || 0;
    const t = cant * precio;
    row.querySelector('.fpi-total').textContent = t > 0 ? fmt(t) : '—';
    total += t;
  });
  const el = document.getElementById('fp-total');
  if (el) el.textContent = fmt(total);
}

function agregarFilaCompra() {
  const idx = filaCompraIdx++;
  const cont = document.getElementById('cc-compras');
  const div = document.createElement('div');
  div.className = 'tabla-fila compras';
  div.id = `fcc-${idx}`;
  div.innerHTML = `
    <input type="date" class="fcc-fecha" value="${hoy()}">
    <input type="text" class="fcc-desc" placeholder="Producto...">
    <input type="number" class="fcc-cant" placeholder="1" min="0" oninput="calcCC()">
    <input type="number" class="fcc-precio" placeholder="0" min="0" oninput="calcCC()">
    <span class="total-cell fcc-total">—</span>
    <button class="del-btn" onclick="document.getElementById('fcc-${idx}').remove(); calcCC()">✕</button>
  `;
  cont.appendChild(div);
}

function agregarFilaPago() {
  const idx = filaPagoIdx++;
  const cont = document.getElementById('cc-pagos');
  const div = document.createElement('div');
  div.className = 'tabla-fila pagos';
  div.id = `fcp-${idx}`;
  div.innerHTML = `
    <input type="date" class="fcp-fecha" value="${hoy()}">
    <input type="text" class="fcp-forma" placeholder="Efectivo / Transf...">
    <input type="text" class="fcp-recibo" placeholder="001">
    <input type="number" class="fcp-monto" placeholder="0" min="0" oninput="calcCC()">
    <button class="del-btn" onclick="document.getElementById('fcp-${idx}').remove(); calcCC()">✕</button>
  `;
  cont.appendChild(div);
}

function calcCC() {
  let totalC = 0;
  document.querySelectorAll('#cc-compras .tabla-fila').forEach(row => {
    const cant = parseFloat(row.querySelector('.fcc-cant')?.value) || 0;
    const precio = parseFloat(row.querySelector('.fcc-precio')?.value) || 0;
    const t = cant * precio;
    row.querySelector('.fcc-total').textContent = t > 0 ? fmt(t) : '—';
    totalC += t;
  });
  let totalP = 0;
  document.querySelectorAll('#cc-pagos .tabla-fila').forEach(row => {
    totalP += parseFloat(row.querySelector('.fcp-monto')?.value) || 0;
  });
  const saldo = totalC - totalP;
  const elC = document.getElementById('cc-total-compras');
  const elP = document.getElementById('cc-total-pagado');
  const elS = document.getElementById('cc-saldo');
  if (elC) elC.textContent = fmt(totalC);
  if (elP) elP.textContent = fmt(totalP);
  if (elS) elS.textContent = fmt(saldo);
  const box = document.getElementById('cc-saldo-box');
  if (box) box.style.background = saldo <= 0 ? 'var(--verde2)' : 'var(--rojo)';
}

// ══════════════════════════════════════════
// GUARDAR
// ══════════════════════════════════════════
function guardarPresupuesto(num) {
  const items = [];
  document.querySelectorAll('#fp-items .tabla-fila').forEach(row => {
    items.push({
      fecha: row.querySelector('.fpi-fecha')?.value || '',
      desc: row.querySelector('.fpi-desc')?.value || '',
      cant: parseFloat(row.querySelector('.fpi-cant')?.value) || 0,
      precio: parseFloat(row.querySelector('.fpi-precio')?.value) || 0,
    });
  });
  const total = items.reduce((s, i) => s + (i.cant * i.precio), 0);
  const ap = document.getElementById('fp-apellido')?.value || '';
  const no = document.getElementById('fp-nombre')?.value || '';
  const de = document.getElementById('fp-desc')?.value || '';

  const obj = {
    id: Date.now(),
    num,
    fecha: document.getElementById('fp-fecha')?.value || hoy(),
    apellido: ap,
    nombre: no,
    desc: de,
    tel: document.getElementById('fp-tel')?.value || '',
    items,
    total,
    estado: document.getElementById('fp-estado')?.value || 'Pendiente',
    obs: document.getElementById('fp-obs')?.value || '',
    nombreArchivo: nombreArchivo('presupuestos', num, ap, no, de),
  };

  const lista = DB.get('presupuestos');
  lista.push(obj);
  DB.set('presupuestos', lista);
  filaPresupIdx = 0;
  volverDeForm();
  actualizarStats();
}

function guardarCuenta(num) {
  const compras = [];
  document.querySelectorAll('#cc-compras .tabla-fila').forEach(row => {
    compras.push({
      fecha: row.querySelector('.fcc-fecha')?.value || '',
      desc: row.querySelector('.fcc-desc')?.value || '',
      cant: parseFloat(row.querySelector('.fcc-cant')?.value) || 0,
      precio: parseFloat(row.querySelector('.fcc-precio')?.value) || 0,
    });
  });
  const pagos = [];
  document.querySelectorAll('#cc-pagos .tabla-fila').forEach(row => {
    pagos.push({
      fecha: row.querySelector('.fcp-fecha')?.value || '',
      forma: row.querySelector('.fcp-forma')?.value || '',
      recibo: row.querySelector('.fcp-recibo')?.value || '',
      monto: parseFloat(row.querySelector('.fcp-monto')?.value) || 0,
    });
  });
  const ap = document.getElementById('cc-apellido')?.value || '';
  const no = document.getElementById('cc-nombre')?.value || '';
  const de = document.getElementById('cc-desc')?.value || '';

  const obj = {
    id: Date.now(),
    num,
    fecha: document.getElementById('cc-fecha')?.value || hoy(),
    apellido: ap,
    nombre: no,
    desc: de,
    tel: document.getElementById('cc-tel')?.value || '',
    compras,
    pagos,
    estado: document.getElementById('cc-estado')?.value || 'Pendiente',
    obs: document.getElementById('cc-obs')?.value || '',
    nombreArchivo: nombreArchivo('cuentas', num, ap, no, de),
  };

  const lista = DB.get('cuentas');
  lista.push(obj);
  DB.set('cuentas', lista);
  filaCompraIdx = 0;
  filaPagoIdx = 0;
  volverDeForm();
  actualizarStats();
}

function guardarOrden(num) {
  const ap = document.getElementById('ot-apellido')?.value || '';
  const no = document.getElementById('ot-nombre')?.value || '';
  const de = document.getElementById('ot-desc')?.value || '';

  const obj = {
    id: Date.now(),
    num,
    fecha: document.getElementById('ot-fecha')?.value || hoy(),
