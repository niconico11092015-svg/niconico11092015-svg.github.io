<script>
// ══════════════════════════════════════════
// DATOS
// ══════════════════════════════════════════
const DB = {
  get(key) { try { return JSON.parse(localStorage.getItem('mc_' + key) || '[]'); } catch(e) { return []; } },
  set(key, val) { localStorage.setItem('mc_' + key, JSON.stringify(val)); },
  nextNum(key) {
    const items = this.get(key);
    if (!items.length) return 1;
    return Math.max(...items.map(i => i.num || 0)) + 1;
  }
};

function fmt(n) { return '$ ' + Math.round(n || 0).toLocaleString('es-AR'); }
function fmtFecha(f) { if (!f) return ''; const [y,m,d] = f.split('-'); return `${d}/${m}/${y}`; }
function hoy() { return new Date().toISOString().split('T')[0]; }
function prefijo(tipo) { return tipo === 'presupuestos' ? 'PRE' : tipo === 'cuentas' ? 'CC' : 'OT'; }

function nombreArchivo(tipo, num, apellido, nombre, desc) {
  const pre = prefijo(tipo);
  const n = String(num || '').padStart(3, '0');
  const ap = (apellido || '').trim();
  const no = (nombre || '').trim();
  const de = (desc || '').trim().substring(0, 25);
  let r = `${pre}-${n}`;
  if (ap) r += `-${ap}`;
  if (no) r += ` ${no}`;
  if (de) r += `-${de}`;
  return r;
}

// ══════════════════════════════════════════
// NAVEGACIÓN
// ══════════════════════════════════════════
let pantallaActual = 'home';
let historial = [];

function irA(pantalla) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('screen-' + pantalla).classList.add('active');
  const nb = document.getElementById('nav-' + pantalla);
  if (nb) nb.classList.add('active');
  document.getElementById('navbar').style.display = 'flex';
  pantallaActual = pantalla;
  if (['presupuestos','cuentas','ordenes'].includes(pantalla)) renderLista(pantalla);
  if (pantalla === 'home') actualizarStats();
}

function mostrarForm() {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-form').classList.add('active');
  document.getElementById('navbar').style.display = 'none';
}

function mostrarDetalle() {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-detalle').classList.add('active');
  document.getElementById('navbar').style.display = 'none';
}

function volverDeForm() { irA(pantallaActual); }
function volverDeDetalle() { irA(pantallaActual); }

// ══════════════════════════════════════════
// STATS HOME
// ══════════════════════════════════════════
function actualizarStats() {
  document.getElementById('stat-presup').textContent = DB.get('presupuestos').length;
  document.getElementById('stat-cc').textContent = DB.get('cuentas').length;
  document.getElementById('stat-ot').textContent = DB.get('ordenes').length;
  const saldo = DB.get('cuentas').reduce((s, cc) => {
    const totalCompras = (cc.compras || []).reduce((a, c) => a + ((parseFloat(c.cant)||0)*(parseFloat(c.precio)||0)), 0);
    const totalPagado = (cc.pagos || []).reduce((a, p) => a + (parseFloat(p.monto)||0), 0);
    return s + Math.max(0, totalCompras - totalPagado);
  }, 0);
  document.getElementById('stat-saldo').textContent = fmt(saldo);
}

// ══════════════════════════════════════════
// LISTA
// ══════════════════════════════════════════
function renderLista(tipo) {
  const items = DB.get(tipo);
  const busq = (document.getElementById('buscar-' + (tipo === 'cuentas' ? 'cc' : tipo === 'presupuestos' ? 'presup' : 'ot'))?.value || '').toLowerCase();
  const cont = document.getElementById('lista-' + tipo);

  const filtrados = items.filter(i => {
    const txt = `${i.apellido} ${i.nombre} ${i.desc} ${i.num}`.toLowerCase();
    return txt.includes(busq);
  });

  if (!filtrados.length) {
    cont.innerHTML = `<div class="empty-state"><div class="e-ico">${tipo === 'presupuestos' ? '📋' : tipo === 'cuentas' ? '💰' : '🔧'}</div><p>No hay ${tipo} todavía.<br>Tocá ＋ para agregar.</p></div>`;
    return;
  }

  cont.innerHTML = filtrados.map(item => {
    let totalCompras = 0, saldoPend = 0;
    if (tipo === 'cuentas') {
      totalCompras = (item.compras||[]).reduce((a,c) => a+((parseFloat(c.cant)||0)*(parseFloat(c.precio)||0)),0);
      const totalPagado = (item.pagos||[]).reduce((a,p) => a+(parseFloat(p.monto)||0),0);
      saldoPend = totalCompras - totalPagado;
    }
    const total = tipo === 'presupuestos' ? (item.total || 0) : tipo === 'cuentas' ? totalCompras : (item.costo || 0);
    const codigo = `${prefijo(tipo)}-${String(item.num).padStart(3,'0')}`;
    const badge = item.estado === 'Pagado' || item.estado === 'Completado' ? 'badge-ok' :
                  item.estado === 'En progreso' ? 'badge-prog' : 'badge-pend';

    return `<div class="item-card ${tipo === 'presupuestos' ? 'presup' : tipo === 'cuentas' ? 'cc' : 'ot'}" onclick="verDetalle('${tipo}', ${item.id})">
      <div class="item-top">
        <span class="item-codigo">${codigo}</span>
        <span class="item-fecha">${fmtFecha(item.fecha)}</span>
      </div>
      <div class="item-nombre">${item.apellido || ''} ${item.nombre || ''}</div>
      <div class="item-desc">${item.desc || '—'}</div>
      <div class="item-footer">
        <span class="item-total">${fmt(tipo === 'cuentas' ? saldoPend : total)}</span>
        <span class="item-badge ${badge}">${item.estado || 'Pendiente'}</span>
      </div>
    </div>`;
  }).join('');
}

