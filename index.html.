// ══════════════════════════════════════════
// DETALLE / ELIMINAR
// ══════════════════════════════════════════
function verDetalle(tipo, id) {
  const items = DB.get(tipo);
  const item = items.find(i => i.id === id);
  if (!item) return;

  document.getElementById('detalle-titulo').textContent = `${prefijo(tipo)}-${String(item.num).padStart(3,'0')}`;

  let html = `<div class="detalle-header">
    <div class="dh-codigo">${item.nombreArchivo || ''}</div>
    <div class="dh-nombre">${item.apellido || ''} ${item.nombre || ''}</div>
    <div class="dh-desc">${item.desc || ''}</div>
    <div class="dh-footer">
      <span class="dh-fecha">📅 ${fmtFecha(item.fecha)}</span>
      <span class="item-badge ${item.estado === 'Pagado' || item.estado === 'Completado' || item.estado === 'Entregado' ? 'badge-ok' : item.estado === 'En progreso' ? 'badge-prog' : 'badge-pend'}">${item.estado || 'Pendiente'}</span>
    </div>
  </div>`;

  if (tipo === 'presupuestos' && item.items?.length) {
    html += `<div class="form-card"><h3>📦 Ítems</h3>
    <div class="tabla-header compras"><span>Fecha</span><span>Descripción</span><span>Cant</span><span>P.Unit</span><span>Total</span><span></span></div>`;
    item.items.forEach(it => {
      html += `<div class="tabla-fila compras" style="pointer-events:none">
        <span style="font-size:12px">${fmtFecha(it.fecha)}</span>
        <span style="font-size:12px">${it.desc}</span>
        <span style="font-size:12px;text-align:right">${it.cant}</span>
        <span style="font-size:12px;text-align:right">${fmt(it.precio)}</span>
        <span class="total-cell">${fmt(it.cant*it.precio)}</span>
        <span></span>
      </div>`;
    });
    html += `<div class="tabla-total"><span>TOTAL</span><span class="tv">${fmt(item.total)}</span></div></div>`;
  }

  if (tipo === 'cuentas') {
    const totalC = (item.compras||[]).reduce((a,c) => a+((c.cant||0)*(c.precio||0)),0);
    const totalP = (item.pagos||[]).reduce((a,p) => a+(p.monto||0),0);
    const saldo = totalC - totalP;

    if (item.compras?.length) {
      html += `<div class="form-card"><h3>📦 Compras</h3>
      <div class="tabla-header compras"><span>Fecha</span><span>Descripción</span><span>Cant</span><span>P.Unit</span><span>Total</span><span></span></div>`;
      item.compras.forEach(c => {
        html += `<div class="tabla-fila compras" style="pointer-events:none">
          <span style="font-size:12px">${fmtFecha(c.fecha)}</span>
          <span style="font-size:12px">${c.desc}</span>
          <span style="font-size:12px;text-align:right">${c.cant}</span>
          <span style="font-size:12px;text-align:right">${fmt(c.precio)}</span>
          <span class="total-cell">${fmt(c.cant*c.precio)}</span>
          <span></span>
        </div>`;
      });
      html += `<div class="tabla-total"><span>TOTAL COMPRAS</span><span class="tv">${fmt(totalC)}</span></div></div>`;
    }

    if (item.pagos?.length) {
      html += `<div class="form-card"><h3>💳 Pagos</h3>
      <div class="tabla-header pagos"><span>Fecha</span><span>Forma</span><span>Recibo</span><span>Monto</span><span></span></div>`;
      item.pagos.forEach(p => {
        html += `<div class="tabla-fila pagos" style="pointer-events:none">
          <span style="font-size:12px">${fmtFecha(p.fecha)}</span>
          <span style="font-size:12px">${p.forma}</span>
          <span style="font-size:12px;text-align:right">${p.recibo}</span>
          <span class="total-cell">${fmt(p.monto)}</span>
          <span></span>
        </div>`;
      });
      html += `<div class="tabla-total"><span>TOTAL PAGADO</span><span class="tv">${fmt(totalP)}</span></div></div>`;
    }

    html += `<div class="resumen-box">
      <div class="res-row compras"><span class="rl">Total compras</span><span class="rv">${fmt(totalC)}</span></div>
      <div class="res-row pagado"><span class="rl">Total pagado</span><span class="rv">${fmt(totalP)}</span></div>
    </div>
    <div class="saldo-final" style="background:${saldo<=0?'var(--verde2)':'var(--rojo)'}">
      <div class="sf-label">${saldo<=0?'✅ Saldo saldado':'⚠ Saldo pendiente'}</div>
      <div class="sf-val">${fmt(Math.abs(saldo))}</div>
    </div>`;
  }

  if (tipo === 'ordenes') {
    html += `<div class="form-card"><h3>📋 Detalles</h3>`;
    if (item.operario) html += `<div class="form-row"><label>Operario</label><div style="padding:8px 0;font-size:14px">${item.operario}</div></div>`;
    if (item.entrega) html += `<div class="form-row"><label>Fecha entrega</label><div style="padding:8px 0;font-size:14px">${fmtFecha(item.entrega)}</div></div>`;
    if (item.prioridad) html += `<div class="form-row"><label>Prioridad</label><div style="padding:8px 0;font-size:14px">${item.prioridad}</div></div>`;
    if (item.materiales) html += `<div class="form-row"><label>Materiales</label><div style="padding:8px 0;font-size:13px;color:var(--gris)">${item.materiales}</div></div>`;
    if (item.costo) html += `<div class="form-row"><label>Costo estimado</label><div style="padding:8px 0;font-size:15px;font-weight:700;color:var(--marron2)">${fmt(item.costo)}</div></div>`;
    if (item.notas) html += `<div class="form-row"><label>Notas</label><div style="padding:8px 0;font-size:13px;color:var(--gris)">${item.notas}</div></div>`;
    html += `</div>`;
  }

  if (item.obs) {
    html += `<div class="form-card"><h3>📝 Observaciones</h3><p style="font-size:13px;color:var(--gris)">${item.obs}</p></div>`;
  }

  html += `<div class="btn-row">
    <button class="btn btn-danger" onclick="eliminarItem('${tipo}', ${id})">🗑 Eliminar</button>
    <button class="btn btn-pdf" onclick="imprimirItem('${tipo}', ${id})">🖨 PDF</button>
  </div>`;

  document.getElementById('detalle-content').innerHTML = html;
  mostrarDetalle();
}

function eliminarItem(tipo, id) {
  if (!confirm('¿Eliminar este registro?')) return;
  const lista = DB.get(tipo).filter(i => i.id !== id);
  DB.set(tipo, lista);
  volverDeDetalle();
  actualizarStats();
}

function imprimirItem(tipo, id) {
  window.print();
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
actualizarStats();
</script>
